{
  "deno.enable": true,
  "deno.unstable": true,
  "deno.config": "./deno.json",
  "deno.lint": true,
  "deno.codeLens.test": true,

  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  },
  // 保存时格式化
  "editor.formatOnSave": true,
  "[json]": {
    "editor.defaultFormatter": "denoland.vscode-deno"
  }
}
